GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GitHub OAuth App (create one at https://github.com/settings/developers)
# Authorization callback URL must exactly match GITHUB_OAUTH_REDIRECT_URI below.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
FRONTEND_URL=http://localhost:3000

# Fallback repo polled when a student hasn't connected GitHub yet, or for
# local dev before any OAuth app is configured.
GITHUB_OWNER=test-user
GITHUB_REPO=test-repo

# Fernet key for encrypting stored OAuth tokens at rest (Integration Spec
# §6.1). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
